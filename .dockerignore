# Docker ignore patterns
# Ignore node_modules - will be installed in container
node_modules
npm-debug.log

# Ignore Next.js build output - will be built in container  
.next
out

# Ignore development files
.env*.local
.env.development

# Ignore Git files
.git
.gitignore

# Ignore IDE files
.idea
.vscode
*.swp
*.swo
*~

# Ignore test files
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Ignore documentation
README.md
docs

# Ignore CI/CD files
.github

# Ignore cache directories
.cache
.turbo

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore Docker files (don't copy into container)
Dockerfile*
docker-compose*.yml
.dockerignore

# Ignore brain/artifacts directory
.gemini
