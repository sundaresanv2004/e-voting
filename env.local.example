# Supabase Configuration
# Get these values from your Supabase project dashboard at:
# https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL
# Found in: Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co

# Your Supabase publishable key (or anon key)
# Found in: Project Settings > API > Project API keys
# Use the new publishable key format (sb_publishable_xxx) if available, 
# otherwise use the legacy anon key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here

# Optional: Service role key (for server-side operations that bypass RLS)
# WARNING: Never expose this key to the client-side!
# Found in: Project Settings > API > Project API keys > service_role
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
