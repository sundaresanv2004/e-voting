# Database Connection (from prisma/.env)
# Organization Name (used in the UI)
NEXT_PUBLIC_APP_NAME="E-Voting System"

# Resend API Key for Email Verification
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY="re_123456789"
EMAIL_FROM="E-Voting <verify@yourdomain.com>"

# This points to the default Postgres mapping if you're using docker-compose
DATABASE_URL="postgresql://user:password@localhost:5432/evoting-db?schema=public"

# Auth.js / NextAuth Configuration
# Generate a secret with: npx auth secret
AUTH_SECRET="your-32-character-secret-here"

# Google OAuth Credentials
# Setup guide: https://console.cloud.google.com/apis/credentials
# 1. Create a project -> Enable "Google+ API" or "Google Identity"
# 2. Go to "Credentials" -> "Create Credentials" -> "OAuth 2.0 Client ID"
# 3. Application type: Web application
# 4. Authorized JavaScript origins: http://localhost:3000
# 5. Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
# For production, replace localhost:3000 with your actual domain
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
