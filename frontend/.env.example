# Prisma Database Connection
# This points to the default Postgres mapping from the docker-compose setup
DATABASE_URL="postgresql://myuser:mypassword@localhost:5432/e_voting?schema=public"

# Auth.js / NextAuth Configuration
# Run `npx auth secret` to generate a secure secret, or use `openssl rand -base64 32`
AUTH_SECRET="replace-me-with-a-secure-random-string"
